---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found" description="That page seems to have cleansed itself away.">
  <div class="wrap">
    <section class="notfound">
      <p class="code serif">404</p>
      <h1>That page cleansed itself away.</h1>
      <p>The link may be old, or the page moved. Let's get you back to the good stuff.</p>
      <a class="btn btn-primary" href="/">Back to the journal</a>
    </section>
  </div>
</BaseLayout>
