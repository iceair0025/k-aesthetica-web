---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Newsletter from '../components/Newsletter.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  headings: MarkdownHeading[];
  related: CollectionEntry<'posts'>[];
}
const { post, headings, related } = Astro.props;
const { title, description, category, kicker, author, pubDate, readMinutes, thumb, hangul } = post.data;

const dateStr = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const toc = headings.filter((h) => h.depth === 2);
const url = new URL(`/posts/${post.id}/`, Astro.site).toString();
const shareX = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
const shareReddit = `https://www.reddit.com/submit?url=${encodeURIComponent(url)}&title=${encodeURIComponent(title)}`;
---
<BaseLayout title={title} description={description} article={true}>
  <article class="article">
    <div class="wrap">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="dot"></span>
        <a href={`/category/${category.toLowerCase()}/`}>{category}</a>
      </nav>

      <header class="article-head">
        <span class="kicker">{kicker ?? category}</span>
        <h1>{title}</h1>
        <p class="standfirst">{description}</p>
        <div class="meta">
          <span>{author}</span><span class="dot"></span>
          <span>{readMinutes} min read</span><span class="dot"></span>
          <span>{dateStr}</span>
        </div>
      </header>

      <div class={`article-hero ${thumb}`}>
        {hangul && <span class="hangul">{hangul}</span>}
      </div>

      {toc.length > 1 && (
        <nav class="callout" style="max-width:680px;margin:44px auto 0;" aria-label="Table of contents">
          <strong>In this article</strong>
          <ul style="margin:.6em 0 0;padding-left:1.2em;">
            {toc.map((h) => <li><a href={`#${h.slug}`}>{h.text}</a></li>)}
          </ul>
        </nav>
      )}

      <div class="prose">
        <slot />
      </div>

      <div class="article-foot">
        <div class="share">
          <span>Share:</span>
          <a href={shareX} target="_blank" rel="noopener">X / Twitter</a>
          <a href={shareReddit} target="_blank" rel="noopener">Reddit</a>
          <button type="button" class="js-copy" data-url={url}>Copy link</button>
        </div>
        <p class="disclaimer">K-Aesthetica shares personal experience and general information, not medical advice. Patch test new products and see a dermatologist for persistent skin concerns.</p>
      </div>
    </div>
  </article>

  {related.length > 0 && (
    <section class="wrap related">
      <div class="sec-head"><h2>Keep reading</h2><a href="/">All posts →</a></div>
      <div class="grid">
        {related.map((p) => <PostCard post={p} />)}
      </div>
    </section>
  )}

  <div class="wrap">
    <Newsletter />
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('button.js-copy').forEach((btn) => {
    const b = btn as HTMLButtonElement;
    b.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(b.dataset.url || location.href);
        const original = b.textContent;
        b.textContent = 'Copied ✓';
        setTimeout(() => (b.textContent = original), 1800);
      } catch {
        b.textContent = 'Copy failed';
      }
    });
  });
</script>
